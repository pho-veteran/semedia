# Database Configuration
POSTGRES_DB=semedia
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

# Database URL (used by services)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/semedia

# Media Storage
MEDIA_ROOT=/app/storage
MEDIA_BASE_URL=/media

# Service URLs (internal Docker network)
MEDIA_WORKER_URL=http://media-worker:8000
SEARCH_API_URL=http://search-api:8000

# ML Configuration
ML_DEVICE=auto
ML_STRICT_CUDA=1
ML_PRELOAD_MODELS=1

# CLIP Model (Hugging Face transformers CLIPModel-compatible checkpoints)
# Supported models (VRAM estimates for fp16 inference):
#   - openai/clip-vit-base-patch32 (default, 151M params, ~600MB VRAM, fast)
#   - openai/clip-vit-base-patch16 (151M params, ~600MB VRAM, higher resolution)
#   - openai/clip-vit-large-patch14 (428M params, ~1.7GB VRAM, best quality)
#   - openai/clip-vit-large-patch14-336 (428M params, ~1.7GB VRAM, 336px input)
#   - laion/CLIP-ViT-B-32-laion2B-s34B-b79K (~600MB VRAM, OpenCLIP trained on LAION-2B)
#   - laion/CLIP-ViT-L-14-laion2B-s32B-b82K (~1.7GB VRAM, OpenCLIP large variant)
CLIP_MODEL_NAME=openai/clip-vit-base-patch32

# Caption Model (Hugging Face BLIP or BLIP-2 checkpoints)
# Supported models (VRAM estimates):
#   BLIP (BlipForConditionalGeneration, fp16 on CUDA):
#     - Salesforce/blip-image-captioning-base (default, 223M params, ~900MB VRAM)
#     - Salesforce/blip-image-captioning-large (476M params, ~1.9GB VRAM, better quality)
#   BLIP-2 (Blip2ForConditionalGeneration, 8-bit quantization on CUDA when available):
#     - Salesforce/blip2-opt-2.7b (2.7B params, ~3.5GB VRAM with 8-bit, ~5.5GB fp16)
#     - Salesforce/blip2-opt-6.7b (6.7B params, ~7GB VRAM with 8-bit, ~13GB fp16)
#     - Salesforce/blip2-flan-t5-xl (3B params, ~4GB VRAM with 8-bit, ~6GB fp16)
CAPTION_MODEL_NAME=Salesforce/blip-image-captioning-base

# Video Processing
SCENE_DETECTION_THRESHOLD=27.0

# Search Configuration
SEARCH_VECTOR_WEIGHT=0.7
SEARCH_KEYWORD_WEIGHT=0.3
SEARCH_MAX_RESULTS=20

# CORS Configuration
CORS_ALLOW_ALL_ORIGINS=1

# Build Arguments
INSTALL_GPU_RUNTIME=1
PYTORCH_INDEX_URL=https://download.pytorch.org/whl/cu130

# Frontend Configuration
VITE_API_BASE_URL=http://127.0.0.1:8000

# Port Mappings
GATEWAY_API_PORT=8000
FRONTEND_PORT=4173
